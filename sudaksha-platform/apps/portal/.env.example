# Sudaksha Portal — Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# Never commit `.env` itself — it contains secrets.

# ── Databases ──────────────────────────────────────────────────────────────
SSO_DATABASE_URL=postgresql://user:password@localhost:5432/sudaksha_core
ASSESSMENTS_DATABASE_URL=postgresql://user:password@localhost:5432/sudaksha_assessments

# ── Auth / NextAuth ────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=

# ── AI providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── Redis (SEPL/INT/2026/IMPL-GAPS-01 Step G19) ────────────────────────────
# Used for WRI caching (1h TTL) and Future Intelligence Signals (24h TTL).
# App functions normally if Redis is unreachable — caching just no-ops.
REDIS_URL=redis://localhost:6379

# ── AWS S3 (SEPL/INT/2026/IMPL-GAPS-01 Step G20) ───────────────────────────
# Used for persisting generated report PDFs. App functions normally without
# these — Report.fileUrl simply stays unset for the mock generator.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sudaksha-reports
