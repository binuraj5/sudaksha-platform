model Role {
  id                  String           @id @default(cuid())
  name                String           @unique
  code                String?          @unique
  description         String
  overallLevel        ProficiencyLevel @default(JUNIOR)
  department          String?
  industries          Industry[]
  keyResponsibilities String?
  requiredExperience  String?
  educationRequired   String?
  isActive            Boolean          @default(true)
  createdBy           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tenantId            String?
  status              ApprovalStatus   @default(APPROVED) // DRAFT for new tenant roles

  // NEW: Scope & Visibility
  scope              String           @default("GLOBAL")
  // GLOBAL | ORGANIZATION | DEPARTMENT | TEAM
  
  departmentId       String?          // null = org-wide, set = department-specific
  teamId             String?          // null = dept-wide, set = team-specific
  createdByUserId    String?          // who created this role
  
  // NEW: Experience Level Restriction
  allowedLevels      String[]         @default(["JUNIOR","MIDDLE","SENIOR","EXPERT"])
  // Institutions: ["JUNIOR"] only
  
  // NEW: Global Approval Workflow
  globalSubmissionStatus  String?
  // null | PENDING | APPROVED | REJECTED | CHANGES_REQUESTED
  
  globalSubmittedBy       String?
  globalSubmittedAt       DateTime?
  globalApprovedBy        String?
  globalApprovedAt        DateTime?
  globalRejectionReason   String?
  
  // Soft delete
  deletedAt          DateTime?

  // M1-8 Approval Fields
  visibility      RoleVisibility @default(TENANT_SPECIFIC)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  assessmentModels   AssessmentModel[]
  tenant             Tenant?           @relation(fields: [tenantId], references: [id])
  competencies       RoleCompetency[]
  users              User[]            @relation("UserRole")
  memberCurrent               Member[]                 @relation("MemberCurrentRole")
  memberAspirational          Member[]                 @relation("MemberAspirationalRole")
  roleAssignmentRequestsFromProfile RoleAssignmentRequest[] @relation("RoleAssignmentRequestRole")
  
  // NEW: Relations
  creator            User?             @relation("RoleCreatedBy", fields: [createdByUserId], references: [id])
  
  @@index([scope])
  @@index([tenantId])
  @@index([globalSubmissionStatus])
}

model Competency {
  id                        String                     @id @default(cuid())
  name                      String                     @unique
  description               String
  category                  CompetencyCategory         @default(TECHNICAL)
  industries                Industry[]
  createdBy                 String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  usageCount                Int                        @default(0)
  lastUsedAt                DateTime?
  tenantId                  String?
  status                    ApprovalStatus             @default(APPROVED)
  
  // NEW: Scope & Visibility (same pattern as Role)
  scope              String           @default("GLOBAL")
  // GLOBAL | ORGANIZATION | DEPARTMENT | TEAM
  
  departmentId       String?          // null = org-wide, set = department-specific
  teamId             String?          // null = dept-wide, set = team-specific
  createdByUserId    String?          // who created this competency
  
  // NEW: Experience Level Restriction
  allowedLevels      String[]         @default(["JUNIOR","MIDDLE","SENIOR","EXPERT"])
  
  // NEW: Global Approval
  globalSubmissionStatus  String?
  globalSubmittedBy       String?
  globalSubmittedAt       DateTime?
  globalApprovedBy        String?
  globalApprovedAt        DateTime?
  globalRejectionReason   String?
  
  // Soft delete
  deletedAt          DateTime?
  
  tenant                    Tenant?                    @relation(fields: [tenantId], references: [id])
  indicators                CompetencyIndicator[]
  roleLinks                 RoleCompetency[]
  assessmentModelComponents AssessmentModelComponent[]
  componentLibraryEntries   ComponentLibrary[]
  adaptiveComponentLibraries AdaptiveComponentLibrary[]
  adaptiveSessions         AdaptiveSession[]
  
  // NEW: Relations
  creator            User?             @relation("CompetencyCreatedBy", fields: [createdByUserId], references: [id])
  
  @@index([scope])
  @@index([tenantId])
  @@index([globalSubmissionStatus])
}

model CompetencyIndicator {
  id           String           @id @default(cuid())
  competencyId String
  level        ProficiencyLevel
  type         IndicatorType
  text         String
  order        Int              @default(0)
  weight       Float            @default(1.0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  competency   Competency       @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@index([competencyId, level, type])
  @@index([competencyId, level])
}

model RoleCompetency {
  id            String           @id @default(cuid())
  roleId        String
  competencyId  String
  requiredLevel ProficiencyLevel
  weight        Float            @default(1.0)
  isCritical    Boolean          @default(false)
  order         Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  competency    Competency       @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  role          Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, competencyId])
  @@index([roleId])
}

// Phase 1: Component Library - reusable assessment components
model ComponentLibrary {
  id                 String   @id @default(cuid())
  tenantId           String?
  createdBy          String

  name               String
  description        String?

  componentType      String   // MCQ | SITUATIONAL | CODE | ESSAY | VOICE | VIDEO | PANEL
  competencyId       String
  targetLevel        String   // JUNIOR | MIDDLE | SENIOR | EXPERT

  visibility         String   @default("PRIVATE") // PRIVATE | ORGANIZATION | GLOBAL

  usageCount         Int      @default(0)
  rating             Decimal? @db.Decimal(3, 2)

  questions          Json     // Array of questions
  metadata           Json?

  publishedToGlobal  Boolean  @default(false)
  globalPublishApprovedBy String?
  globalPublishApprovedAt DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant?  @relation(fields: [tenantId], references: [id])
  creator            User     @relation(fields: [createdBy], references: [id])
  competency         Competency @relation(fields: [competencyId], references: [id])
  usedInComponents   AssessmentModelComponent[] @relation("ComponentToLibrary")

  @@index([tenantId])
  @@index([competencyId])
  @@index([componentType])
  @@index([targetLevel])
  @@index([visibility])
}

// Phase 1: Component suggestions by category and level
model ComponentSuggestion {
  id                 String   @id @default(cuid())

  competencyCategory String   // TECHNICAL | BEHAVIORAL | COGNITIVE | DOMAIN_SPECIFIC
  targetLevel        String   // JUNIOR | MIDDLE | SENIOR | EXPERT

  suggestedType      String   // MCQ | SITUATIONAL | CODE | ESSAY | VOICE | VIDEO
  priority           String   // HIGH | MEDIUM | LOW
  reason             String

  createdAt          DateTime @default(now())

  @@index([competencyCategory, targetLevel])
}

// Panel Interview: Scheduling and evaluation (Phase: Panel Interview feature)
model Panel {
  id                String   @id @default(cuid())
  tenantId          String?
  name              String
  description       String?
  durationMinutes   Int      @default(60)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  interviews        PanelInterview[]
  members           PanelMember[]

  @@index([tenantId])
}

model PanelMember {
  id        String   @id @default(cuid())
  panelId   String
  userId    String
  role      String?  // HIRING_MANAGER | TECHNICAL_LEAD | PEER_INTERVIEWER
  createdAt DateTime @default(now())
  panel    Panel    @relation(fields: [panelId], references: [id], onDelete: Cascade)
  evaluations PanelEvaluation[]

  @@index([panelId])
}

model PanelInterview {
  id                  String   @id @default(cuid())
  candidateId         String?  // Member.id or User.id
  panelId             String
  memberAssessmentId   String?  // Links to assessment submission
  componentId         String?  // Links to assessment component
  scheduledTime       DateTime
  durationMinutes     Int      @default(60)
  meetingLink         String?
  status              String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  completedAt         DateTime?
  panel               Panel    @relation(fields: [panelId], references: [id], onDelete: Cascade)
  memberAssessment    MemberAssessment? @relation(fields: [memberAssessmentId], references: [id], onDelete: SetNull)
  component           AssessmentModelComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  evaluations         PanelEvaluation[]

  @@index([panelId])
  @@index([candidateId])
  @@index([status])
  @@index([memberAssessmentId])
  @@index([componentId])
}

model PanelEvaluation {
  id               String    @id @default(cuid())
  panelInterviewId String
  panelistId       String
  panelMemberId    String?
  scores           Json?     // { competencyId: score }
  feedback         String?   @db.Text
  recommendation   String?   // STRONG_HIRE | HIRE | MAYBE | NO_HIRE
  submittedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  panelInterview   PanelInterview @relation(fields: [panelInterviewId], references: [id], onDelete: Cascade)
  panelMember      PanelMember?   @relation(fields: [panelMemberId], references: [id], onDelete: SetNull)

  @@index([panelInterviewId])
}

// Phase 1: Master Assessment Engine - Adaptive AI
model AdaptiveComponentLibrary {
  id           String   @id @default(cuid())
  tenantId     String
  createdBy    String
  name         String
  description  String?
  competencyId String
  targetLevel  String   // JUNIOR | MIDDLE | SENIOR | EXPERT
  config       Json     // min_questions, max_questions, starting_difficulty, etc.
  visibility   String   @default("PRIVATE")
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator    User       @relation(fields: [createdBy], references: [id])
  competency Competency @relation(fields: [competencyId], references: [id])

  @@index([tenantId])
  @@index([competencyId])
}

model AdaptiveSession {
  id                  String    @id @default(cuid())
  memberAssessmentId   String
  componentId          String
  memberId             String
  competencyId         String
  currentAbility      Decimal   @db.Decimal(4, 2)
  initialAbility      Decimal   @db.Decimal(4, 2)
  targetLevel          String
  questionsAsked       Int       @default(0)
  questionsCorrect     Int       @default(0)
  status               String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | ABANDONED
  config               Json
  startedAt            DateTime  @default(now())
  lastActivityAt       DateTime  @default(now())
  completedAt          DateTime?
  finalScore           Decimal?  @db.Decimal(5, 2)
  abilityEstimate      Decimal?  @db.Decimal(4, 2)

  memberAssessment MemberAssessment        @relation(fields: [memberAssessmentId], references: [id], onDelete: Cascade)
  component        AssessmentModelComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  member           Member                  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  competency       Competency              @relation(fields: [competencyId], references: [id])
  questions        AdaptiveQuestion[]

  @@index([memberAssessmentId])
  @@index([componentId])
  @@index([status])
}

model AdaptiveQuestion {
  id                String    @id @default(cuid())
  sessionId         String
  questionText      String    @db.Text
  questionType      String
  options           Json?
  correctAnswer     String?
  explanation       String?   @db.Text
  difficulty        Decimal   @db.Decimal(4, 2)
  sequenceNumber    Int
  generationPrompt  String?   @db.Text
  generatedAt       DateTime  @default(now())
  candidateAnswer   String?   @db.Text
  isCorrect         Boolean?
  timeTakenSeconds  Int?
  answeredAt        DateTime?
  pointsAwarded     Decimal?  @db.Decimal(5, 2)
  maxPoints         Decimal?  @db.Decimal(5, 2)

  session AdaptiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, sequenceNumber])
}

// Phase 1: Global publish requests
model GlobalPublishRequest {
  id                 String   @id @default(cuid())

  entityType         String   // MODEL | COMPONENT
  entityId           String

  requestedBy        String
  requestedAt        DateTime @default(now())

  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy         String?
  reviewedAt        DateTime?
  reviewComments     String?

  requester          User     @relation("PublishRequester", fields: [requestedBy], references: [id])
  reviewer           User?    @relation("PublishReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([entityType, entityId])
}

model ApprovalRequest {
  id                String         @id @default(cuid())
  tenantId          String
  type              ApprovalType
  entityId          String
  status            ApprovalStatus @default(PENDING)
  comments          String?
  requesterId       String?        // ID of the person making the request
  reviewerId        String?        // ID of the Super Admin who reviewed it
  reviewedAt        DateTime?
  rejectionReason   String?

  // Snapshots
  originalData      Json?
  modifiedData      Json?
  modificationNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([requesterId])
  @@index([reviewerId])
}

// Simpler role assignment request from profile (inline "Request role" flow)
model RoleAssignmentRequest {
  id                    String   @id @default(cuid())
  memberId              String
  tenantId              String
  requestedRoleName      String
  description           String?
  totalExperienceYears  Int
  context               String   // 'current' | 'aspirational'
  status                String   @default("PENDING") // PENDING | APPROVED | REJECTED
  assignedRoleId        String?  // Set when admin creates role and assigns
  roleCreatedAt         DateTime?  // Set when admin creates role from approval UI
  processedBy            String?
  processedAt           DateTime?
  rejectionReason       String?
  departmentId          String?  // FK to MasterDepartment; null when departmentOtherText used
  departmentOtherText   String?  // When user selects "Other" department (can be added to MasterDepartment on approval)
  industryId            String?  // FK to MasterIndustry; null when industryOtherText used
  industryOtherText     String?  // When user selects "Other" industry (can be added to MasterIndustry on approval)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  member                Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedRole          Role?    @relation("RoleAssignmentRequestRole", fields: [assignedRoleId], references: [id])
  department            MasterDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  industry              MasterIndustry?   @relation(fields: [industryId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([tenantId])
  @@index([status])
}

// Enhancement #1: Approval audit trail (Phase 3)
model ApprovalHistory {
  id              String   @id @default(cuid())
  entityType      String   // 'ROLE' | 'COMPETENCY'
  entityId        String
  approverRole    String   // 'TEAM_LEAD', 'CLASS_TEACHER', 'DEPT_HEAD', 'SUPER_ADMIN'
  approverUserId  String?
  action          String   // 'SUBMITTED', 'APPROVED', 'REJECTED', 'RESUBMITTED'
  actionAt        DateTime @default(now())
  comments        String?
  iterationNumber Int      @default(1)
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([entityId, iterationNumber])
}

// Enhancement #5: Intelligent Recommendations (Phase 4)
model RecommendationRule {
  id                String   @id @default(cuid())
  category          String?   // 'ASSESSMENT', 'REPORT', 'SURVEY'
  triggerContext    Json?     // Conditions that trigger this recommendation
  recommendationText String?  @db.Text
  rationale         String?   @db.Text
  autoApplyValues   Json?     // Values to auto-fill if user clicks "Apply"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isActive          Boolean   @default(true)
  usage             RecommendationUsage[]

  @@index([category])
}

model RecommendationUsage {
  id        String   @id @default(cuid())
  ruleId    String
  userId    String?
  context   Json?
  action    String   // 'APPLIED', 'DISMISSED', 'MODIFIED'
  createdAt DateTime @default(now())
  rule      RecommendationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([userId])
}

