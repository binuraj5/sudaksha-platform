  assessmentSessionId String
  respondentId        String
  questionText        String
  questionType        String
  difficulty          String
  competencyArea      String
  options             Json?
  correctAnswer       String?
  generatedAt         DateTime  @default(now())
  presentedAt         DateTime?
  answeredAt          DateTime?
