generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trainer {
  id                           String        @id @default(cuid())
  name                         String
  email                        String        @unique
  bio                          String
  expertise                    Json
  experience                   Int
  rating                       Float         @default(0)
  imageUrl                     String?
  linkedinUrl                  String?
  status                       TrainerStatus @default(ACTIVE)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  isPublished                  Boolean       @default(false)
  availableForCourses          Json?
  certifications               Json?
  currentCompany               String?
  currentDesignation           String?
  firstName                    String?
  industriesWorked             Json?
  lastName                     String?
  preferredBatchTypes          Json?
  primaryExpertise             Json?
  profileImageUrl              String?
  secondaryExpertise           Json?
  title                        String?
  totalIndustryExperienceYears Int?
  totalReviews                 Int           @default(0)
  totalStudentsTaught          Int           @default(0)
  totalTeachingExperienceYears Int?
  courses                      Course[]
  batches                      CourseBatch[]
}

model Course {
  id                           String                   @id @default(cuid())
  name                         String
  slug                         String                   @unique
  deliveryMode                 BatchMode                @default(ONLINE)
  industry                     String                   @default("Generic/All Industries")
  isSelfPaced                  Boolean                  @default(false)
  enrollmentUrl                String?
  description                  String
  shortDescription             String?
  duration                     Int
  price                        Float
  rating                       Float                    @default(0)
  status                       CourseStatus             @default(DRAFT)
  audienceLevel                AudienceLevel
  skillTags                    Json
  learningObjectives           Json
  moduleBreakdown              Json
  imageUrl                     String?
  videoUrl                     String?
  language                     String                   @default("English")
  maxStudents                  Int?
  certification                Boolean                  @default(false)
  trainerId                    String
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  prerequisites                String?
  certificateProvider          String?
  certificateType              String?
  corporateAvailable           Boolean                  @default(false)
  cpeCredits                   Decimal?
  customizationAvailable       Boolean                  @default(false)
  durationDays                 Int?
  durationHours                Decimal?
  durationWeeks                Int?
  hasCaseStudies               Boolean                  @default(false)
  hasPersonalActivities        Boolean                  @default(false)
  hasProcessFrameworks         Boolean                  @default(false)
  hasProjects                  Boolean                  @default(false)
  industryRecognition          String?
  maxBatchSize                 Int?
  minBatchSize                 Int?
  newDeliveryModes             DeliveryMode[]
  onsiteAvailable              Boolean                  @default(false)
  prerequisiteText             String?
  publishedAt                  DateTime?
  requiredExperience           String?
  sessionsPerWeek              Int?
  subCategory                  String?
  targetAudience               String?
  targetRoles                  String[]
  technicalRequirements        String?
  title                        String?
  category                     String
  categoryType                 String
  targetLevel                  String
  courseType                   String
  assessmentsJson              Json?
  averagePlacementRate         Decimal?
  averageSalaryHikePercent     Decimal?
  averageSalaryMax             Decimal?
  averageSalaryMin             Decimal?
  basePrice                    Decimal?
  batchType                    BatchTypeDisplay?
  capstoneProjectDescription   String?
  capstoneProjectDurationHours Int?
  capstoneProjectTitle         String?
  careerPaths                  Json?
  categoryPrimary              CategoryPrimary?
  categorySecondary            String?
  certificationName            String?
  classDurationMinutes         Int?
  courseCode                   String?                  @unique
  courseTypeDisplay            CourseTypeDisplay?
  currency                     String?                  @default("INR")
  currentBatchEnrolled         Int                      @default(0)
  deliveryModeJson             Json?
  discountedPrice              Decimal?
  earlyBirdDiscount            Decimal?
  emiAvailable                 Boolean                  @default(false)
  emiOptions                   Json?
  experienceRequired           String?
  featuredOrder                Int?
  finishingSchoolProgram       Boolean                  @default(false)
  groupDiscount                Decimal?
  hoursPerWeek                 Int?
  industrySpecific             Boolean                  @default(false)
  industryVertical             Json?
  isCorporateOnly              Boolean                  @default(false)
  isFeatured                   Boolean                  @default(false)
  isIndividualAvailable        Boolean                  @default(true)
  isNew                        Boolean                  @default(false)
  isTrending                   Boolean                  @default(false)
  lmsCourseId                  String?
  lmsLastSyncAt                DateTime?
  longDescription              String?
  metaDescription              String?
  metaKeywords                 Json?
  metaTitle                    String?
  miniProjects                 Json?
  miniProjectsCount            Int?
  ogImageUrl                   String?
  overallRating                Decimal?
  placementSupport             Boolean                  @default(false)
  prerequisiteSkills           Json?
  primaryTrainerId             String?
  ratingDistribution           Json?
  scheduleDetails              Json?
  skillsGained                 Json?
  statusDisplay                CourseStatusDisplay?
  targetAudienceDisplay        TargetAudienceDisplay?
  technologyDomain             String?
  toolsCovered                 Json?
  topHiringCompanies           Json?
  totalClasses                 Int?
  totalDurationWeeks           Int?
  totalHours                   Int?
  totalLessons                 Int?
  totalModules                 Int?
  totalReviews                 Int                      @default(0)
  totalStudentsTrained         Int                      @default(0)
  trainerExperienceRequired    String?
  trainerPool                  Json?
  newBatches                   Batch[]
  trainer                      Trainer                  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  batches                      CourseBatch[]
  courseFaqs                   CourseFaq[]
  includedFeatures             CourseFeature[]
  instructors                  CourseInstructor[]
  courseMedia                  CourseMedia[]
  modules                      CourseModule[]
  courseOutcomes               CourseOutcome[]
  coursePrerequisites          CoursePrerequisite[]
  reviews                      CourseReview[]
  deliverables                 Deliverable[]
  industrySpecificCourses      IndustrySpecificCourse[]
  learningOutcomes             LearningOutcome[]
  relatedCourses               RelatedCourse[]

  @@index([category, status])
  @@index([status])
  @@index([audienceLevel])
  @@index([rating])
  @@index([price])
  @@index([trainerId])
  @@index([categoryType])
  @@index([industry])
  @@index([targetLevel])
  @@index([courseType])
  @@index([deliveryMode])
  @@index([categoryPrimary])
  @@index([technologyDomain])
  @@index([targetAudienceDisplay])
  @@index([statusDisplay])
  @@index([isFeatured, featuredOrder])
  @@index([overallRating])
}

model FinishingSchool {
  id           String   @id @default(cuid())
  title        String
  description  String
  industry     String   @default("Generic/All Industries")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  categoryType String

  @@index([categoryType])
  @@index([industry])
}

model CourseModule {
  id                  String         @id @default(cuid())
  title               String
  description         String?
  order               Int
  duration            Int
  courseId            String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  handsOnLabs         Json?
  learningObjectives  Json?
  moduleDescription   String?
  moduleDurationHours Int?
  moduleNumber        Int?
  moduleTitle         String?
  topicsCovered       Json?
  lessons             CourseLesson[]
  course              Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([order])
  @@index([courseId, moduleNumber])
}

model CourseLesson {
  id                    String       @id @default(cuid())
  title                 String
  description           String?
  content               String?
  videoUrl              String?
  duration              Int
  order                 Int
  isFree                Boolean      @default(false)
  moduleId              String
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  lessonDescription     String?
  lessonDurationMinutes Int?
  lessonNumber          Int?
  lessonTitle           String?
  lessonType            LessonType?
  resources             Json?
  module                CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([order])
  @@index([moduleId, lessonNumber])
}

model CourseBatch {
  id                String             @id @default(cuid())
  name              String
  courseId          String
  trainerId         String
  startDate         DateTime
  endDate           DateTime
  schedule          String
  mode              BatchMode          @default(ONLINE)
  maxStudents       Int
  currentStudents   Int                @default(0)
  price             Float?
  status            BatchStatus        @default(UPCOMING)
  location          String?
  meetingUrl        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assignedTrainerId String?
  batchCode         String?            @unique
  batchType         BatchTypeDisplay?
  classroomLocation String?
  deliveryMode      BatchDeliveryMode?
  enrolledStudents  Int                @default(0)
  onlinePlatform    String?
  scheduleDetails   Json?
  timezone          String?            @default("IST")
  waitlistCount     Int                @default(0)
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer           Trainer            @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  courseReviews     CourseReview[]

  @@index([courseId])
  @@index([trainerId])
  @@index([startDate, status])
  @@index([status])
  @@index([startDate])
  @@index([courseId, status])
}

model CourseReview {
  id                     String       @id @default(cuid())
  courseId               String
  studentName            String
  studentEmail           String
  rating                 Int
  comment                String?
  verified               Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  batchId                String?
  cons                   String?
  contentQualityRating   Int?
  courseCompletedDate    DateTime?
  isFeatured             Boolean      @default(false)
  isVerified             Boolean      @default(false)
  placementSupportRating Int?
  pros                   String?
  reviewDate             DateTime?
  reviewStatus           ReviewStatus @default(PENDING)
  reviewText             String?
  reviewTitle            String?
  studentCompany         String?
  studentDesignation     String?
  studentId              String?
  studentPhotoUrl        String?
  supportRating          Int?
  trainerRating          Int?
  valueForMoneyRating    Int?
  batch                  CourseBatch? @relation(fields: [batchId], references: [id])
  course                 Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([rating])
  @@index([createdAt])
  @@index([courseId, reviewStatus])
  @@index([isFeatured, rating])
}

model CoursePrerequisite {
  id                      String           @id @default(cuid())
  courseId                String
  prerequisiteType        PrerequisiteType
  prerequisiteTitle       String?
  prerequisiteDescription String?
  sortOrder               Int?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  course                  Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
}

model CourseFaq {
  id         String   @id @default(cuid())
  courseId   String
  question   String
  answer     String
  category   String?
  sortOrder  Int?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
}

model CourseMedia {
  id               String          @id @default(cuid())
  courseId         String
  mediaType        CourseMediaType
  mediaUrl         String
  mediaTitle       String?
  mediaDescription String?
  thumbnailUrl     String?
  isPrimary        Boolean         @default(false)
  sortOrder        Int?
  createdAt        DateTime        @default(now())
  course           Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, mediaType])
}

model CourseOutcome {
  id                         String   @id @default(cuid())
  courseId                   String
  batchId                    String?
  totalStudents              Int?
  studentsPlaced             Int?
  placementRate              Decimal?
  averageSalary              Decimal?
  minSalary                  Decimal?
  maxSalary                  Decimal?
  placementCompanies         Json?
  averagePreAssessmentScore  Decimal?
  averagePostAssessmentScore Decimal?
  skillImprovementPercent    Decimal?
  completionRate             Decimal?
  projectSubmissionRate      Decimal?
  dataPeriod                 String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  course                     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model IndustrySpecificCourse {
  id                          String           @id @default(cuid())
  courseId                    String
  industryVertical            IndustryVertical
  industryChallengesAddressed Json?
  complianceCertifications    Json?
  technologyStackFocus        Json?
  domainKnowledgeIncluded     String?
  industryCaseStudies         Json?
  sampleProjects              Json?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  course                      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([industryVertical])
}

model Communication {
  id         String                 @id @default(cuid())
  type       CommunicationType
  name       String?
  email      String?
  phone      String?
  subject    String?
  message    String
  status     CommunicationStatus    @default(PENDING)
  metadata   Json?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  campaignId String?
  recipients Json?
  sentAt     DateTime               @default(now())
  stats      Json?
  campaign   CommunicationCampaign? @relation(fields: [campaignId], references: [id])

  @@index([type])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@index([campaignId])
}

model CommunicationTemplate {
  id        String            @id @default(cuid())
  name      String
  type      CommunicationType
  subject   String?
  content   String
  variables Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([type])
}

model CommunicationCampaign {
  id              String            @id @default(cuid())
  name            String
  subject         String?
  content         String
  type            CommunicationType
  status          String            @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientsCount Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  communications  Communication[]

  @@index([status])
}

model CTAEvent {
  id         String   @id @default(cuid())
  ctaId      String
  userId     String?
  sessionId  String?
  eventType  String
  pageUrl    String?
  formName   String?
  buttonName String?
  eventData  Json?
  createdAt  DateTime @default(now())

  @@index([ctaId])
  @@index([eventType])
  @@index([createdAt])
}

model AuditLog {
  idEntity   String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  userId     String?
  createdAt  DateTime @default(now())
  entityName String?
  severity   String   @default("INFO")
  status     String   @default("SUCCESS")
  userName   String?

  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([severity])
}

model Blog {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String
  content        String
  author         String
  authorImage    String?
  category       String
  tags           Json
  imageUrl       String?
  status         BlogStatus @default(DRAFT)
  publishedAt    DateTime?
  viewCount      Int        @default(0)
  readTime       Int
  featured       Boolean    @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@index([featured])
  @@index([slug])
}

model Webinar {
  id              String                @id @default(cuid())
  title           String
  slug            String                @unique
  description     String
  speaker         String
  speakerBio      String?
  speakerImage    String?
  date            DateTime
  time            String
  duration        Int
  timezone        String                @default("IST")
  imageUrl        String?
  meetingUrl      String?
  recordingUrl    String?
  status          WebinarStatus         @default(UPCOMING)
  maxAttendees    Int?
  registeredCount Int                   @default(0)
  category        String?
  tags            Json?
  featured        Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  registrations   WebinarRegistration[]

  @@index([status, date])
  @@index([featured])
  @@index([slug])
  @@index([date])
}

model WebinarRegistration {
  id        String   @id @default(cuid())
  webinarId String
  name      String
  email     String
  phone     String?
  company   String?
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())
  webinar   Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId])
  @@index([email])
  @@index([createdAt])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formType  String
  formName  String?
  pageUrl   String
  pageName  String?
  formData  Json
  userAgent String?
  ipAddress String?
  sessionId String?
  status    String   @default("NEW")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formType])
  @@index([status])
  @@index([createdAt])
  @@index([pageUrl])
}

model LearningOutcome {
  id        String   @id @default(cuid())
  courseId  String
  outcome   String
  order     Int
  category  String?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Batch {
  id                   String       @id @default(cuid())
  courseId             String
  batchName            String?
  startDate            DateTime
  endDate              DateTime?
  sessionTimings       String?
  platform             String?
  recordingAccess      Int?
  timezone             String?
  venueName            String?
  venueAddress         String?
  city                 String?
  state                String?
  country              String?
  facilities           String[]
  availableSeats       Int
  totalSeats           Int
  status               BatchStatus  @default(UPCOMING)
  registrationDeadline DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  course               Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments          Enrollment[]

  @@index([courseId])
  @@index([startDate])
}

model CourseInstructor {
  id                    String   @id @default(cuid())
  courseId              String
  name                  String
  title                 String?
  bio                   String?
  photoUrl              String?
  yearsExperience       Int?
  industryExperience    String[]
  expertise             String[]
  certifications        String[]
  education             String?
  companiesWorked       String[]
  linkedinUrl           String?
  websiteUrl            String?
  totalStudentsTaught   Int?
  totalCoursesDelivered Int?
  averageRating         Decimal?
  isPrimary             Boolean  @default(false)
  order                 Int?
  createdAt             DateTime @default(now())
  course                Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseFeature {
  id        String          @id @default(cuid())
  courseId  String
  feature   String
  icon      String?
  order     Int
  category  FeatureCategory
  createdAt DateTime        @default(now())
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Deliverable {
  id          String          @id @default(cuid())
  courseId    String
  title       String
  description String
  type        DeliverableType
  order       Int
  createdAt   DateTime        @default(now())
  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model RelatedCourse {
  id              String       @id @default(cuid())
  courseId        String
  relatedCourseId String
  relationType    RelationType
  order           Int?
  createdAt       DateTime     @default(now())
  course          Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, relatedCourseId])
}

model Enrollment {
  id             String           @id @default(cuid())
  batchId        String
  userId         String
  enrollmentDate DateTime         @default(now())
  status         EnrollmentStatus @default(CONFIRMED)
  amountPaid     Decimal?
  paymentDate    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  batch          Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([userId])
}

model MasterCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterIndustry {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  slug                   String                  @unique
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  roleAssignmentRequests RoleAssignmentRequest[]
}

model MasterDepartment {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  slug                   String                  @unique
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  roleAssignmentRequests RoleAssignmentRequest[]
}

model MasterCourseType {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterLevel {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterDomain {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                                String                     @id @default(cuid())
  email                             String                     @unique
  password                          String
  name                              String
  role                              UserRole                   @default(ASSESSOR)
  clientId                          String?
  employeeId                        String?                    @unique
  department                        String?
  departmentId                      String?
  projectId                         String?
  accountType                       AccountType                @default(INDIVIDUAL)
  isActive                          Boolean                    @default(true)
  emailVerified                     DateTime?
  createdAt                         DateTime                   @default(now())
  updatedAt                         DateTime                   @updatedAt
  assignedRoleId                    String?
  failedAttempts                    Int                        @default(0)
  lockoutUntil                      DateTime?
  userType                          UserType                   @default(TENANT)
  adaptiveComponentLibrariesCreated AdaptiveComponentLibrary[]
  assessorProfile                   AssessorProfile?
  competenciesCreated               Competency[]               @relation("CompetencyCreatedBy")
  componentLibrariesCreated         ComponentLibrary[]
  reviewedApprovals                 GlobalApprovalRequest[]    @relation("ReviewedApprovals")
  submittedApprovals                GlobalApprovalRequest[]    @relation("SubmittedApprovals")
  publishRequestsAsRequester        GlobalPublishRequest[]     @relation("PublishRequester")
  publishRequestsAsReviewer         GlobalPublishRequest[]     @relation("PublishReviewer")
  managedProjects                   ProjectManager[]
  projectAssessments                ProjectUserAssessment[]
  reports                           Report[]
  rolesCreated                      Role[]                     @relation("RoleCreatedBy")
  assignedRole                      Role?                      @relation("UserRole", fields: [assignedRoleId], references: [id])
  client                            Client?                    @relation(fields: [clientId], references: [id])
  dept                              Department?                @relation(fields: [departmentId], references: [id])
  proj                              Project?                   @relation(fields: [projectId], references: [id])
  assessments                       UserAssessmentModel[]

  @@index([email])
  @@index([employeeId])
  @@index([clientId])
  @@index([accountType])
}

model AssessorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  employeeId         String
  departmentUnit     String
  currentDesignation String
  reportingManager   String
  dateOfJoining      DateTime
  yearsInCurrentRole Float
  educationalQual    String
  professionalCerts  String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ComponentQuestion {
  id               String                      @id @default(cuid())
  componentId      String
  questionText     String
  questionType     QuestionType
  points           Int                         @default(1)
  timeLimit        Int?
  order            Int                         @default(0)
  options          Json?
  correctAnswer    String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  linkedIndicators String[]
  explanation      String?
  metadata         Json?
  component        AssessmentModelComponent    @relation(fields: [componentId], references: [id], onDelete: Cascade)
  responses        ComponentQuestionResponse[]

  @@index([componentId])
}

model AssessmentModel {
  id                       String                     @id @default(cuid())
  name                     String
  slug                     String                     @unique
  description              String?
  sourceType               ModelSourceType            @default(ROLE_BASED)
  roleId                   String?
  targetLevel              ProficiencyLevel?          @default(JUNIOR)
  visibility               String                     @default("PRIVATE")
  clientId                 String?
  version                  String                     @default("1.0.0")
  isActive                 Boolean                    @default(true)
  createdBy                String
  createdAt                DateTime                   @default(now())
