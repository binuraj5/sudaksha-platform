  DEPARTMENT_HEAD
  TEAM_LEAD
  SUPERVISOR
}

enum ProficiencyLevel {
  JUNIOR
  MIDDLE
  SENIOR
  EXPERT
}

enum CompetencyCategory {
  TECHNICAL
  BEHAVIORAL
  COGNITIVE
  DOMAIN_SPECIFIC
}

enum IndicatorType {
  POSITIVE
  NEGATIVE
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalType {
  ROLE
  COMPETENCY
}

enum SurveyQuestionType {
  LIKERT
  MCQ
  MSQ
  RATING
  TEXT
  NPS
  SLIDER
  DATE
  YES_NO
}

enum SurveyTargetType {
  ALL
  DEPARTMENT
  TEAM
  ROLE
  CUSTOM
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Survey {
  id             String             @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  purpose        String?
  status         SurveyStatus       @default(DRAFT)
  targetAudience String?
  scoringEnabled Boolean            @default(false)
  scoringMethod  String?            @default("AVERAGE")
  metadata       Json? // settings, branding, emails
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions      SurveyQuestion[]
  assignments    SurveyAssignment[]
  responses      SurveyResponse[]

  @@index([tenantId])
}

model SurveyQuestion {
  id           String             @id @default(cuid())
  surveyId     String
  questionText String
  questionType SurveyQuestionType
  options      Json? // For MCQ, MSQ, Likert
  order        Int
  isRequired   Boolean            @default(true)
  points       Float?             @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  survey       Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers      SurveyAnswer[]

  @@index([surveyId])
}

model SurveyAssignment {
  id               String           @id @default(cuid())
  surveyId         String
  targetType       SurveyTargetType
  targetId         String? // ID of Dept, Team, or Role
  assignedAt       DateTime         @default(now())
  dueDate          DateTime?
  reminderSettings Json?
  survey           Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model SurveyResponse {
  id          String         @id @default(cuid())
  surveyId    String
  memberId    String? // NULL if anonymous
  score       Float?
  completedAt DateTime       @default(now())
  metadata    Json? // device, browser, etc
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  member      Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  answers     SurveyAnswer[]

  @@index([surveyId])
  @@index([memberId])
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  questionId String
  answerData Json // The actual answer
  points     Float?
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
}

model CodeSubmission {
  id          String   @id @default(cuid())
  challengeId String
  problemId   String
  memberId    String
  code        String
  language    String
  status      String
  score       Float
  createdAt   DateTime @default(now())
}

model ReportTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  type        String? // PDF, EXCEL, CSV
  config      Json // Data sources, metrics, visualizations default config
  isSystem    Boolean @default(false)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isSystem])
  @@index([tenantId])
}

model Report {
  id         String @id @default(cuid())
  tenantId   String
  templateId String
  userId     String

  name    String
  filters Json? // Applied filters

  generatedAt DateTime  @default(now())
  expiresAt   DateTime?
  fileUrl     String? // S3 or local path
  status      String    @default("COMPLETED") // PENDING, PROCESSING, COMPLETED, FAILED

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template ReportTemplate @relation(fields: [templateId], references: [id])
  user     User           @relation(fields: [userId], references: [id]) // Creator
  member   Member?        @relation(fields: [memberId], references: [id]) // Optional Member Link
  memberId String?

  schedules ReportSchedule[]

  @@index([tenantId])
  @@index([userId])
}

model ReportSchedule {
  id         String  @id @default(cuid())
  reportId   String
  frequency  String // DAILY, WEEKLY, MONTHLY
  recipients Json // Array of emails
  isActive   Boolean @default(true)

  lastRunAt DateTime?
  nextRunAt DateTime?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
}

enum SubscriptionTier {
  STARTER
  GROWTH
  BUSINESS
  ENTERPRISE
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum UserType {
  SUPER_ADMIN
  TENANT
  INDIVIDUAL
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  INVITED
}

model AdminUser {
  id                String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String
  twoFactorSecret    String?
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// NEW TABLE: Global Approval Requests Queue
model GlobalApprovalRequest {
  id                 String   @id @default(cuid())
  
  entityType         String   // ROLE | COMPETENCY
  entityId           String
  
  tenantId           String
  submittedBy        String
  submittedAt        DateTime @default(now())
  
  status             String   @default("PENDING")
  // PENDING | APPROVED | REJECTED | CHANGES_REQUESTED
  
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNotes        String?
  
  // Snapshot of what was submitted (for review)
  entitySnapshot     Json     // Full role/competency data at time of submission
  
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  submitter          User     @relation("SubmittedApprovals", fields: [submittedBy], references: [id])
  reviewer           User?    @relation("ReviewedApprovals", fields: [reviewedBy], references: [id])
  
  @@index([status])
  @@index([tenantId])
  @@index([entityType, entityId])
}
